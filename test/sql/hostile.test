# name: test/sql/hostile.test
# group: [vgi_pe]
#
# Hostile input survival: garbage bytes / non-binary input must never crash the
# worker. Binaries are untrusted malware samples by definition. Scalars -> NULL;
# table functions -> no rows. The worker stays up and keeps serving.

require-env VGI_PE_WORKER

statement ok
LOAD vgi;

statement ok
ATTACH 'pe' AS pe (TYPE vgi, LOCATION '${VGI_PE_WORKER}');

# garbage.bin is not an executable at all. Scalars degrade to NULL.

query I
SELECT pe.binary_format('test/sql/data/garbage.bin') IS NULL;
----
true

query I
SELECT pe.machine('test/sql/data/garbage.bin') IS NULL;
----
true

query I
SELECT pe.is_signed('test/sql/data/garbage.bin') IS NULL;
----
true

query I
SELECT pe.section_count('test/sql/data/garbage.bin') IS NULL;
----
true

query I
SELECT pe.overall_entropy('test/sql/data/garbage.bin') IS NULL;
----
true

query I
SELECT pe.imphash('test/sql/data/garbage.bin') IS NULL;
----
true

# A nonexistent path also degrades to NULL for scalars (never an error).
query I
SELECT pe.binary_format('test/sql/data/does_not_exist.bin') IS NULL;
----
true

# Table functions over garbage yield NO ROWS (not an error, not a crash).
query I
SELECT count(*) FROM pe.sections('test/sql/data/garbage.bin');
----
0

query I
SELECT count(*) FROM pe.imports('test/sql/data/garbage.bin');
----
0

query I
SELECT count(*) FROM pe.exports('test/sql/data/garbage.bin');
----
0

# Crucially: the worker is still alive and serving a real binary after all the
# hostile input above.
query I
SELECT pe.binary_format('test/sql/data/hello.exe');
----
PE

query I
SELECT pe.section_count('test/sql/data/hello.exe') > 0;
----
true

statement ok
DETACH pe;
